      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "hive_capability_invocation_duration_ms{quantile=\"0.5\"}",
          "legendFormat": "{{ capability }} p50",
          "refId": "A"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "hive_capability_invocation_duration_ms{quantile=\"0.9\"}",
          "legendFormat": "{{ capability }} p90",
          "refId": "B"
