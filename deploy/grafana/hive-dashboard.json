        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 5 },
      "id": 6,
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showUnfilled": true
      },
      "title": "Agent Heartbeat Health",
      "type": "bargauge",
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "hive_heartbeat_healthy",
          "legendFormat": "{{ agent_id }}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 101,
      "title": "Capability Invocations",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "invocations/sec",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Capability Invocation Rate",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "rate(hive_capability_invocation_duration_ms_count[5m])",
          "legendFormat": "{{ capability }}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "ms",
