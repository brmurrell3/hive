        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "hive_agents_total{status=\"failed\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
