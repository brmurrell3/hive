        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "Pending Agents",
      "type": "stat",
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "hive_agents_total{status=\"pending\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
